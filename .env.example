PORT=3000
RUNS_DIR=/app/data/runs
IDEAS_DIR=/app/data/ideas
CREDENTIALS_DIR=/app/data/credentials
ADMIN_TOKEN=replace-with-a-random-dashboard-token
# Optional teammate tokens. Format: user_id:token,user_id_2:token_2
DASHBOARD_USERS=teammate-a:replace-with-random-token,teammate-b:replace-with-random-token
# Required for per-user encrypted BRAIN credential storage. Use a long random value.
CREDENTIALS_SECRET=replace-with-long-random-secret
OPENAI_API_KEY=replace-with-server-side-openai-key
OPENAI_IDEA_MODEL=gpt-5.4-mini
ALPHA_MINER_ENGINE=python-v2
PYTHON_BIN=python3
PHASE0_VISUALIZATION_PROBE=0
PHASE0_SPECULATIVE_ENDPOINT_PROBE=0
AUTO_RUN_ENABLED=true
AUTO_RUN_OWNER_ID=default
AUTO_RUN_MODE=loop
AUTO_RUN_INTERVAL_MINUTES=60
AUTO_RUN_OBJECTIVE=robust operating-income quality with low crowding and positive test stability
AUTO_RUN_BATCH_SIZE=3
AUTO_RUN_ROUNDS=2
AUTO_REPAIR_ENABLED=true
AUTO_REPAIR_ENGINE=legacy-js
AUTO_REPAIR_MAX_ROUNDS=5
AUTO_REPAIR_BATCH_SIZE=5
AUTO_SUBMIT_ENABLED=true
ALPHA_GENERATOR_STRATEGY=legacy
ALPHA_EXPERIMENTAL_FIELDS=false
ALPHA_CROWDING_PATTERN_THRESHOLD=2
ALPHA_FAMILY_COOLDOWN_ROUNDS=3
WQB_EMAIL=your-email@example.com
WQB_PASSWORD=your-password

# Multi-LLM Router
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
LLM_ROUTER_ENABLED=false
LLM_BUDGET_DAILY_USD=3.60
KNOWLEDGE_DISTILL_ENABLED=false
IDEA_OPTIMIZER_MODEL=claude-sonnet-4-5
